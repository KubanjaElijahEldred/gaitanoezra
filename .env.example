# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ---------------------------------------------------------------------------
# Instagram live stats (used by /api/instagram)
# ---------------------------------------------------------------------------

# Provider: "manual" (default) reads numbers from env vars below.
# Set to "rapidapi" and provide RAPIDAPI_KEY for real-time scraping.
INSTAGRAM_API_PROVIDER="manual"

# RapidAPI credentials (only needed when INSTAGRAM_API_PROVIDER=rapidapi).
# Subscribe to an Instagram scraper API on RapidAPI, e.g.:
# https://rapidapi.com/santimattius/api/instagram-scraper-api2
RAPIDAPI_KEY="MY_RAPIDAPI_KEY"
RAPIDAPI_HOST="instagram-scraper-api2.p.rapidapi.com"

# Instagram account details.
INSTAGRAM_USERNAME="geatano_ezra"

# Manual fallback numbers shown when INSTAGRAM_API_PROVIDER=manual.
# Update these in the Vercel dashboard to refresh the portfolio values.
INSTAGRAM_FOLLOWERS="0"
INSTAGRAM_FOLLOWING="0"
INSTAGRAM_POSTS="0"

# Featured reel: https://www.instagram.com/reel/DaNpsp2KCYF/
REEL_VIEWS="0"
REEL_LIKES="0"
REEL_COMMENTS="0"
REEL_CAPTION=""
REEL_THUMBNAIL=""
